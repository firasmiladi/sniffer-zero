{
    "name": "{{ name | default('sniffer-rt Coverage') }}",
    "versions": {
        "attack": "14",
        "navigator": "4.9.1",
        "layer": "4.5"
    },
    "domain": "enterprise-attack",
    "description": "{{ description | default('ATT&CK techniques tested by sniffer-rt modules') }}",
    "filters": {
        "platforms": ["Network", "Linux", "Windows", "macOS"]
    },
    "sorting": 0,
    "layout": {
        "layout": "side",
        "aggregateFunction": "average",
        "showID": true,
        "showName": true,
        "showAggregateScores": false,
        "countUnscored": false
    },
    "hideDisabled": false,
    "techniques": [
        {% for t in techniques %}
        {
            "techniqueID": "{{ t.technique_id }}",
            "tactic": "{{ t.tactic | default('') }}",
            "score": {{ t.score | default(1) }},
            "color": "{% if t.score >= 3 %}#08519c{% elif t.score >= 2 %}#3182bd{% else %}#6baed6{% endif %}",
            "comment": "{{ t.comment | default('') }}",
            "enabled": true
        }{% if not loop.last %},{% endif %}
        {% endfor %}
    ],
    "gradient": {
        "colors": ["#6baed6", "#3182bd", "#08519c"],
        "minValue": 1,
        "maxValue": 3
    },
    "legendItems": [
        {"label": "1 module", "color": "#6baed6"},
        {"label": "2 modules", "color": "#3182bd"},
        {"label": "3+ modules", "color": "#08519c"}
    ],
    "metadata": [],
    "links": [],
    "showTacticRowBackground": true,
    "tacticRowBackground": "#dddddd",
    "selectTechniquesAcrossTactics": true,
    "selectSubtechniquesWithParent": false,
    "selectVisibleTechniques": false
}
